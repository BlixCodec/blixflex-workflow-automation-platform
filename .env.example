# =============================================================================
# BlixFlex — Example environment configuration
# -----------------------------------------------------------------------------
# This file documents the NAMES of configuration variables only.
# All values are placeholders. NEVER commit a real .env file or real secrets.
# Copy to `.env` locally and fill in real values from your own secret manager.
# =============================================================================

# ---- App ----
APP_ENV=development
APP_BASE_URL=http://localhost:5173

# ---- Supabase (backend / auth / database) ----
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only   # server-side only — never expose to the client
SUPABASE_PROJECT_REF=your-project-ref

# ---- Frontend-exposed (Vite) ----
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# ---- Payments (Stripe) ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ---- Email delivery ----
EMAIL_API_KEY=your-email-provider-api-key
EMAIL_FROM_ADDRESS=operations@example.com

# ---- Web Push (VAPID) ----
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:operations@example.com

# ---- Discord (community operations) ----
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# ---- Automation / scheduled jobs ----
CRON_SHARED_SECRET=your-shared-secret-for-authenticating-scheduled-jobs
